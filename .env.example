# Supabase — get from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to client. Used by Auth Hook + admin scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Owner email — used by Supabase Auth Hook to stamp `role: owner` JWT claim.
# Single value, builder's permanent maintainer email.
OWNER_EMAIL=
